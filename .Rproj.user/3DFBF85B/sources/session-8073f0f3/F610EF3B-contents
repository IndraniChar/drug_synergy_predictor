server <- function(input, output, session) {
  
  values <- reactiveValues(
    current_prediction = NULL,
    current_explanation = NULL
  )
  
  # Handle suggestion buttons
  observeEvent(input$suggest1, {
    updateTextAreaInput(session, "ai_query", value = "What are the best immunotherapy combinations for NSCLC?")
    Sys.sleep(0.2)
    session$sendCustomMessage("click_ask", list())
    ask_ai_click()
  })
  
  observeEvent(input$suggest2, {
    updateTextAreaInput(session, "ai_query", value = "Explain PARP inhibitor synergy with platinum chemotherapy")
    Sys.sleep(0.2)
    ask_ai_click()
  })
  
  observeEvent(input$suggest3, {
    updateTextAreaInput(session, "ai_query", value = "What biomarkers predict response to checkpoint inhibitors?")
    Sys.sleep(0.2)
    ask_ai_click()
  })
  
  observeEvent(input$suggest4, {
    updateTextAreaInput(session, "ai_query", value = "Summarize Phase III trials for PD-1 combination therapies")
    Sys.sleep(0.2)
    ask_ai_click()
  })
  
  ask_ai_click <- function() {
    query <- tolower(input$ai_query)
    
    if(grepl("immunotherapy|pembrolizumab|nivolumab|nsclc", query)) {
      response <- paste0(
        "IMMUNOTHERAPY COMBINATIONS FOR NSCLC\n\n",
        "PEMBROLIZUMAB + CHEMOTHERAPY (Cisplatin/Pemetrexed)\n",
        "  - Synergy Score: 52.3/100 (SYNERGISTIC)\n",
        "  - Mechanism: Chemo-induced immunogenic cell death\n",
        "  - KEYNOTE-189: HR 0.49 for overall survival\n",
        "  - FDA approved for first-line treatment\n\n",
        "NIVOLUMAB + IPILIMUMAB (Dual Checkpoint Blockade)\n",
        "  - CheckMate-227: Improved OS regardless of PD-L1\n",
        "  - Higher response rates in TMB-H tumors\n\n",
        "PREDICTIVE BIOMARKERS:\n",
        "  - PD-L1 expression (TPS/CPS)\n",
        "  - Tumor Mutational Burden (TMB)\n",
        "  - MSI-H/dMMR status"
      )
    } else if(grepl("parp", query)) {
      response <- paste0(
        "PARP INHIBITOR SYNERGY MECHANISM\n\n",
        "OLAPARIB + PLATINUM CHEMOTHERAPY\n",
        "  - Synergy Score: 65-75/100 (STRONG SYNERGY)\n",
        "  - Mechanism: Synthetic lethality in HRD tumors\n",
        "  - Approved for BRCA-mutated cancers\n\n",
        "CRITICAL BIOMARKERS (Required):\n",
        "  - BRCA1/2 mutation - ESSENTIAL\n",
        "  - Homologous Recombination Deficiency (HRD) score\n",
        "  - RAD51 foci formation\n\n",
        "CLINICAL TRIALS:\n",
        "  - POLO: 7.4 months PFS benefit in pancreatic cancer\n",
        "  - PROfound: Improved rPFS in prostate cancer\n",
        "  - OlympiA: Improved invasive DFS in breast cancer"
      )
    } else if(grepl("biomarker", query)) {
      response <- paste0(
        "PREDICTIVE BIOMARKERS FOR COMBINATION THERAPY\n\n",
        "PD-L1 EXPRESSION\n",
        "  - IHC assay (22C3, SP263, SP142 clones)\n",
        "  - Cutoffs: 1%% (moderate), 50%% (high)\n",
        "  - Predicts benefit from checkpoint inhibitors\n\n",
        "TUMOR MUTATIONAL BURDEN (TMB)\n",
        "  - TMB-H defined as >=10 mut/Mb\n",
        "  - Predicts response to dual immunotherapy\n\n",
        "MISMATCH REPAIR (MMR) / MSI STATUS\n",
        "  - Pan-cancer predictor for pembrolizumab\n\n",
        "HOMOLOGOUS RECOMBINATION DEFICIENCY (HRD)\n",
        "  - Predicts PARP inhibitor sensitivity\n",
        "  - Genomic instability score >=42 = HRD+"
      )
    } else if(grepl("phase iii|trial", query)) {
      response <- paste0(
        "MAJOR PHASE III TRIALS FOR COMBINATION THERAPY\n\n",
        "KEYNOTE-189 (NSCLC)\n",
        "  - Regimen: Pembrolizumab + Pemetrexed + Platinum\n",
        "  - HR for OS: 0.49 (p < 0.0001)\n\n",
        "CheckMate-9LA (NSCLC)\n",
        "  - Regimen: Nivolumab + Ipilimumab + Chemo\n",
        "  - HR for OS: 0.79 (p = 0.011)\n\n",
        "KEYNOTE-355 (TNBC)\n",
        "  - Regimen: Pembrolizumab + Chemotherapy\n",
        "  - HR for PFS: 0.65 (CPS >=10)\n\n",
        "POLO (Pancreatic, BRCA mutant)\n",
        "  - Regimen: Olaparib maintenance\n",
        "  - Median PFS: 7.4 vs 3.8 months"
      )
    } else {
      response <- paste0(
        "AI ASSISTANT RESPONSE\n\n",
        "Based on current literature and clinical trial data:\n\n",
        "- The combination landscape in oncology is rapidly evolving\n",
        "- Major trials are investigating IO + IO and IO + targeted combinations\n",
        "- Biomarker-driven selection is crucial for optimal outcomes\n\n",
        "Tip: Try asking about specific drug names, cancer types,\n",
        "biomarkers, or clinical trials for more detailed responses!"
      )
    }
    
    output$ai_response <- renderText({ response })
  }
  
  # Automatic ask trigger via observe
  observeEvent(input$ask_ai, {
    ask_ai_click()
  })
  
  # Prediction
  observeEvent(input$predict_btn, {
    values$current_prediction <- predict_synergy(input$drug1, input$drug2, input$cancer_type)
    values$current_explanation <- get_ai_explanation(
      input$drug1, input$drug2, input$cancer_type,
      values$current_prediction$loewe_score,
      values$current_prediction$synergy_class
    )
    
    showNotification(
      paste("Analysis complete:", input$drug1, "+", input$drug2),
      type = "message",
      duration = 3
    )
  })
  
  # Predicted score value box
  output$predicted_score <- renderValueBox({
    if(is.null(values$current_prediction)) {
      valueBox(
        value = tags$div(style = "font-size: 18px;", "Ready to Predict"),
        subtitle = "Select drugs and click the button",
        icon = icon("magic"),
        color = "purple"
      )
    } else {
      score <- values$current_prediction$loewe_score
      color <- ifelse(score > 35, "green", ifelse(score > 0, "yellow", "red"))
      valueBox(
        value = tags$div(style = "font-size: 32px; font-weight: bold;", paste0(round(score, 1), "/100")),
        subtitle = tags$div(style = "font-size: 14px;", 
                            paste("Synergy Score -", values$current_prediction$synergy_class)),
        icon = icon("chart-line"),
        color = color
      )
    }
  })
  
  # Synergy result text
  output$synergy_result <- renderText({
    if(is.null(values$current_prediction)) {
      "Ready for analysis - select drugs and cancer type above"
    } else {
      paste("RESULT:", values$current_prediction$drug1, "+", 
            values$current_prediction$drug2, "for", values$current_prediction$cancer_type, 
            "Cancer ->", values$current_prediction$synergy_class, 
            "Combination | Clinical Status:", values$current_prediction$clinical_trial_phase)
    }
  })
  
  # AI explanation
  output$ai_explanation <- renderText({
    if(is.null(values$current_explanation)) {
      "Click 'Predict Synergy' to receive AI-powered mechanistic explanation with clinical evidence, biomarker guidance, and recommended validation pathways."
    } else {
      values$current_explanation
    }
  })
  
  # AI Assistant responses
  output$ai_response <- renderText({
    "Ask a question about drug combinations, mechanisms, or clinical trials using the box above."
  })
  
  # Top combinations table
  output$top_combinations_table <- renderDT({
    top_combos <- synergy_data %>%
      filter(loewe_score > 35) %>%
      arrange(desc(loewe_score)) %>%
      head(20) %>%
      select(
        `First Drug` = drug1, 
        `Second Drug` = drug2, 
        `Cancer Type` = cancer_type, 
        `Synergy Score` = loewe_score, 
        `Phase` = clinical_trial_phase,
        `Classification` = synergy_class
      )
    
    datatable(top_combos, 
              options = list(
                pageLength = 10, 
                scrollX = TRUE,
                dom = 'Bfrtip',
                buttons = c('copy', 'csv')
              ),
              rownames = FALSE, 
              class = 'cell-border stripe hover') %>%
      formatRound(columns = "Synergy Score", digits = 1) %>%
      formatStyle("Synergy Score",
                  background = styleColorBar(c(20, 100), "#F06292"),
                  backgroundSize = '100% 90%',
                  backgroundRepeat = 'no-repeat')
  })
  
  # Synergy heatmap
  output$synergy_heatmap <- renderPlotly({
    top_drugs <- unique(c(synergy_data$drug1, synergy_data$drug2))[1:10]
    heatmap_data <- matrix(0, nrow = length(top_drugs), ncol = length(top_drugs))
    rownames(heatmap_data) <- top_drugs
    colnames(heatmap_data) <- top_drugs
    
    for(i in 1:length(top_drugs)) {
      for(j in 1:length(top_drugs)) {
        if(i != j) {
          match_idx <- which(
            (synergy_data$drug1 == top_drugs[i] & synergy_data$drug2 == top_drugs[j]) |
              (synergy_data$drug1 == top_drugs[j] & synergy_data$drug2 == top_drugs[i])
          )
          if(length(match_idx) > 0) {
            heatmap_data[i, j] <- mean(synergy_data$loewe_score[match_idx], na.rm = TRUE)
          } else {
            heatmap_data[i, j] <- NA
          }
        }
      }
    }
    
    plot_ly(z = heatmap_data, x = top_drugs, y = top_drugs, type = "heatmap",
            colorscale = list(c(0, "#C2185B"), c(0.5, "#F8BBD0"), c(1, "#9B59B6")),
            hovertemplate = "%{x} + %{y}<br>Synergy Score: %{z:.1f}<extra></extra>",
            showscale = TRUE) %>%
      layout(title = list(text = "Drug Synergy Interaction Matrix", 
                          font = list(color = "#C2185B", size = 16, weight = "bold")),
             xaxis = list(title = "", tickangle = -45, tickfont = list(size = 11)),
             yaxis = list(title = "", tickfont = list(size = 11)),
             plot_bgcolor = '#FCE4EC',
             paper_bgcolor = '#FCE4EC',
             height = 600)
  })
  
  # Cancer boxplot
  output$cancer_boxplot <- renderPlotly({
    p <- ggplot(synergy_data, aes(x = cancer_type, y = loewe_score, fill = cancer_type)) +
      geom_boxplot(alpha = 0.8, outlier.size = 3, outlier.color = "#E91E63", 
                   outlier.alpha = 0.6, width = 0.6) +
      geom_hline(yintercept = 35, linetype = "dashed", color = "#E91E63", size = 1.2, alpha = 0.7) +
      geom_hline(yintercept = 0, linetype = "dashed", color = "#9B59B6", size = 1, alpha = 0.5) +
      scale_fill_manual(values = c(
        "Breast" = "#F06292",
        "Lung" = "#E91E63",
        "Colorectal" = "#C2185B",
        "Pancreatic" = "#9B59B6",
        "Ovarian" = "#7B2D8E",
        "Melanoma" = "#4A0E4E"
      )) +
      theme_minimal(base_size = 12) +
      theme(
        plot.background = element_rect(fill = "transparent", color = NA),
        panel.background = element_rect(fill = "white", color = NA),
        panel.grid.major = element_line(color = "#F3E5F5", size = 0.5),
        panel.grid.minor = element_blank(),
        plot.title = element_text(hjust = 0.5, color = "#C2185B", size = 16, face = "bold"),
        axis.title.y = element_text(color = "#6A1B9A", face = "bold"),
        legend.position = "none"
      ) +
      labs(title = "Synergy Scores by Cancer Type", 
           x = "", 
           y = "Loewe Synergy Score (0-100)")
    
    ggplotly(p) %>%
      layout(plot_bgcolor = '#FCE4EC', paper_bgcolor = '#FCE4EC')
  })
  
  # Phase pie chart
  output$phase_pie <- renderPlotly({
    phase_counts <- table(synergy_data$clinical_trial_phase)
    plot_ly(labels = names(phase_counts), values = as.numeric(phase_counts), type = "pie",
            marker = list(colors = c("#E91E63", "#F06292", "#C2185B", "#9B59B6")),
            textinfo = "label+percent",
            hovertemplate = "%{label}<br>Count: %{value}<extra></extra>") %>%
      layout(title = list(text = "Clinical Trial Phase Distribution", 
                          font = list(color = "#C2185B", size = 16)),
             plot_bgcolor = '#FCE4EC',
             paper_bgcolor = '#FCE4EC')
  })
  
  # Value boxes
  output$total_combinations <- renderValueBox({
    valueBox(
      value = tags$div(style = "font-size: 32px;", format(nrow(synergy_data), big.mark = ",")),
      subtitle = "Total Drug Combinations Analyzed",
      icon = icon("capsules"),
      color = "purple"
    )
  })
  
  output$synergistic_count <- renderValueBox({
    n_synergistic <- sum(synergy_data$loewe_score > 35)
    pct <- round(n_synergistic/nrow(synergy_data)*100, 1)
    valueBox(
      value = tags$div(style = "font-size: 28px;", paste0(pct, "%")),
      subtitle = "Synergistic Combinations (Score > 35)",
      icon = icon("thumbs-up"),
      color = "green"
    )
  })
  
  output$clinical_trials <- renderValueBox({
    n_trials <- sum(grepl("Phase II|Phase III", synergy_data$clinical_trial_phase))
    valueBox(
      value = tags$div(style = "font-size: 28px;", n_trials),
      subtitle = "Advanced Phase Clinical Trials",
      icon = icon("hospital"),
      color = "blue"
    )
  })
  
  # Full data table
  output$full_data_table <- renderDT({
    display_data <- synergy_data %>%
      select(`Drug 1` = drug1, `Drug 2` = drug2, `Cancer Type` = cancer_type,
             `Loewe Score` = loewe_score, `Bliss Score` = bliss_score, 
             `ZIP Score` = zip_score, `Phase` = clinical_trial_phase, 
             `Classification` = synergy_class)
    
    datatable(display_data, 
              options = list(
                pageLength = 25, 
                scrollX = TRUE,
                dom = 'Bfrtip',
                buttons = c('copy', 'csv', 'excel')
              ),
              rownames = FALSE,
              class = 'cell-border stripe hover') %>%
      formatRound(columns = c("Loewe Score", "Bliss Score", "ZIP Score"), digits = 1) %>%
      formatStyle("Loewe Score",
                  background = styleColorBar(c(-20, 100), "#F06292"),
                  backgroundSize = '100% 90%',
                  backgroundRepeat = 'no-repeat')
  })
}

# Run the app
shinyApp(ui = ui, server = server)