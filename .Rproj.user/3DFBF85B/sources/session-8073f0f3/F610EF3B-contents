# ============================================
# GENERATE SYNTHETIC DRUG SYNERGY DATA
# ============================================

generate_synergy_data <- function() {
  set.seed(42)
  
  drugs <- c(
    "Pembrolizumab", "Nivolumab", "Cisplatin", "Carboplatin", 
    "Docetaxel", "Paclitaxel", "Gemcitabine", "5-Fluorouracil",
    "Oxaliplatin", "Irinotecan", "Bevacizumab", "Cetuximab",
    "Trastuzumab", "Olaparib", "Venetoclax", "Ibrutinib"
  )
  
  cancer_types <- c("Breast", "Lung", "Colorectal", "Pancreatic", "Ovarian", "Melanoma")
  
  n_pairs <- 350
  drug_pairs <- data.frame()
  
  for(i in 1:n_pairs) {
    drug1 <- sample(drugs, 1)
    drug2 <- sample(drugs[drugs != drug1], 1)
    base_synergy <- runif(1, -20, 85)
    
    if(grepl("mab", drug1) && grepl("platin", drug2)) {
      base_synergy <- base_synergy + 35
    }
    if(grepl("PARP", drug1) || grepl("PARP", drug2)) {
      base_synergy <- base_synergy + 30
    }
    if(grepl("nib", drug1) || grepl("nib", drug2)) {
      base_synergy <- base_synergy + 20
    }
    
    drug_pairs <- rbind(drug_pairs, data.frame(
      drug1 = drug1,
      drug2 = drug2,
      cancer_type = sample(cancer_types, 1),
      loewe_score = round(pmin(100, pmax(-20, base_synergy + rnorm(1, 0, 8))), 1),
      bliss_score = round(pmin(100, pmax(-20, base_synergy + rnorm(1, 0, 7))), 1),
      zip_score = round(pmin(100, pmax(-20, base_synergy + rnorm(1, 0, 9))), 1),
      clinical_trial_phase = sample(c("Phase I", "Phase II", "Phase III", "Approved"), 1, 
                                    prob = c(0.35, 0.35, 0.2, 0.1)),
      stringsAsFactors = FALSE
    ))
  }
  
  drug_pairs <- unique(drug_pairs)
  drug_pairs$synergy_class <- ifelse(
    drug_pairs$loewe_score > 35, "SYNERGISTIC",
    ifelse(drug_pairs$loewe_score < 0, "ANTAGONISTIC", "ADDITIVE")
  )
  drug_pairs$color_code <- ifelse(
    drug_pairs$loewe_score > 35, "#E91E63",
    ifelse(drug_pairs$loewe_score > 15, "#9B59B6", "#C39BD3")
  )
  
  return(drug_pairs)
}

synergy_data <- generate_synergy_data()

# ============================================
# PREDICTION FUNCTION
# ============================================

predict_synergy <- function(drug1, drug2, cancer_type) {
  match_idx <- which(
    ((synergy_data$drug1 == drug1 & synergy_data$drug2 == drug2) |
       (synergy_data$drug1 == drug2 & synergy_data$drug2 == drug1)) &
      synergy_data$cancer_type == cancer_type
  )
  
  if(length(match_idx) > 0) {
    return(synergy_data[match_idx[1], ])
  } else {
    cancer_scores <- synergy_data[synergy_data$cancer_type == cancer_type, "loewe_score"]
    avg_score <- mean(cancer_scores)
    return(data.frame(
      drug1 = drug1,
      drug2 = drug2,
      cancer_type = cancer_type,
      loewe_score = round(avg_score, 1),
      bliss_score = round(avg_score, 1),
      zip_score = round(avg_score, 1),
      synergy_class = ifelse(avg_score > 35, "SYNERGISTIC", 
                             ifelse(avg_score < 0, "ANTAGONISTIC", "ADDITIVE")),
      clinical_trial_phase = "Predicted",
      color_code = ifelse(avg_score > 35, "#E91E63", ifelse(avg_score > 15, "#9B59B6", "#C39BD3"))
    ))
  }
}

